! NAME:   .xmodmap
! AUTHOR: marsh
!
!   If you want to change keycode, you should 
! use `xev` to check it.
! And after changing .Xmodmap, you put `xmodmap $HOME/.Xmodmap`
!
!   Each keysym column in the table corresponds to a particular combination of modifier keys:
! 1. key
! 2. Shift+key
! 3. Mode_switch+key
! 4. Mode_switch+Shift+key
! 5. ISO_Level3_Shift+key
! 6. ISO_Level3_Shift+Shift+key

!
! Add suepr key.
! kana and henkan to super key
!
! keycode 102: muhenkan
! keycode 100: henkan
! keycode 101: katakana hiragana romazi
!keycode 102 = Super_L
!keycode 100 = Super_R
!keycode 101 = Super_R
!
!!
!! Caps_Lock to Control_L
!!
!clear lock
!clear control
clear lock
clear control

keycode 66 = Control_L
add control = Control_L Control_R


!
! keycode 49 is Zenkaku_Hankaku
!
keysym Zenkaku_Hankaku = Zenkaku_Hankaku

clear lock
clear control

keycode 66 = Control_L
add control = Control_L Control_R
!keycode 66 = Control_L
!add control = Control_L Control_R
