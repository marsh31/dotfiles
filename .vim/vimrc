fun! GetModename() abort

  let l:st           = ''
  let l:timeout_icon = ['󰔞 ', '󰔛 ']
  let l:main         = s:get_main_mode_name()
  let l:sub          = submode#current()

  let l:st ..= (l:timeout_icon[&timeout] .. l:main)
  if ! empty(l:sub)
    let l:st ..= l:sub
  endif
  return ( l:st .. ' ' )
endfun

fun! MyStatusLine()
