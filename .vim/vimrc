" tabline {{{1
"
"  'tabclose'        'tcl'         タブを閉じるときにどのタブページにフォーカスするか
"  'tabline'         'tal'         コンソールのタブページラインのカスタムフォーマット
"  'tabpagemax'      'tpm'         タブページの最大数。|-p|と "tab all" に使われる

set tabclose=left

fun! MyTabLabel(n)
  let l:buflist = tabpagebuflist(a:n)
  let l:winnr   = tabpagewinnr(a:n)
  let l:name    = fnamemodify(bufname(l:buflist[l:winnr - 1]), ':t')

  if l:name ==# ''
    let l:name  = '[No Name]'
  endif

  return printf("%2d.%s", a:n, l:name)
endfun

fun! MyTabline()
  let l:showmax    = 5
  let l:ctabpagenr = tabpagenr()
  let l:tabpagemax = tabpagenr('$')
  let s = ''

  " tab count
  let s ..= '%#TabLine#'
  let s ..= printf(' %2d/%d ', l:ctabpagenr, tabpagenr('$'))

  " tab list
  let l:tabstart   = l:ctabpagenr
  let l:tabend     = min([(l:ctabpagenr+l:showmax-1), tabpagenr('$')])
  if ((l:tabend - l:tabstart + 1) < l:showmax)
    let l:tabstart -= (l:showmax - (l:tabend - l:tabstart + 1))
    let l:tabstart = max([l:tabstart, 1])
  endif
  for i in range(l:tabstart, l:tabend)
    if i == tabpagenr()
      let s ..= '%#TabLineSel#'
    else
      let s ..= '%#TabLine#'
    endif

    let s ..= '%' .. (i) .. 'T'
    let s ..= ' %{MyTabLabel(' .. (i) .. ')} '
  endfor


  " 最後のタブページの後は TabLineFill で埋め、タブページ番号をリセットする
  let s ..= '%#TabLineFill#%T'

  " カレントタブページを閉じるボタンのラベルを右添えで作成
  " NOTE: 使わないため削除
  " if tabpagenr('$') > 1
  "   let s ..= '%=%#TabLine#%999Xclose'
  " endif

  return s
endfun
set tabline=%!MyTabline()


