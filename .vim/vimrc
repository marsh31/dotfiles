" find/grep/make {{{1
"
" 'findfunc'        'ffu'   |:find| コマンドで呼び出される関数
" 'grepformat'      'gfm'   'grepprg' の出力の書式
" 'grepprg'         'gp'    |:grep|で使う外部プログラム
"
"
" 'makeef'          'mef'         |:make|用のエラーファイル
" 'makeencoding'    'menc'        外部 make/grep コマンドのエンコーディング
" 'makeprg'         'mp'          |:make|で使う外部プログラム
"


fun! s:RgFindFunc(cmdarg, cmdcomplete)
  let l:result = systemlist('rg --files | rg ' . a:cmdarg)
  if v:shell_error != 0
    echoerr l:result
    return []
  endif
  return l:result
endfun

if executable('rg')
  set findfunc=s:RgFindFunc
  set grepprg=rg\ --vimgrep\ -H\ --no-heading
  set grepformat=%f:%l:%c:%m
endif


