" function {{{1
fun! s:show_highlight_group()
  let l:hlgroup = synIDattr(synID(line('.'), col('.'), 1), 'name')
  let l:group_chain = []

  while l:hlgroup !=# ''
    call add(l:group_chain, hlgroup)
    let l:hlgroup = matchstr(trim(execute('hi ' .. l:hlgroup)), '\<links\s\+to\>\s\+\zs\w\+$')
  endwhile

  if empty(l:group_chain)
    echomsg 'No highlight groups'
    return
  endif

  for l:group in l:group_chain
    execute 'hi ' .. l:group
  endfor
endfun



