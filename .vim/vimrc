" Plugin Install {{{1
"
" 最低限のプラグインのインストールに制限する。
" できれば自分で作れるものは作ってみたい。

call plug#begin()
  Plug 'vim-jp/vimdoc-ja'
  Plug 'mattn/vim-sonictemplate'

  Plug 'kana/vim-operator-user'

  Plug 'kana/vim-submode'

  Plug 'junegunn/vim-easy-align'

  " textobj-user
  " operator-user
  " surround
  " expand yank
  " notification
  " partedit
  " ripgrep
call plug#end()

