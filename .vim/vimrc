" 'foldnestmax'     'fdn'        折り畳みの深さの制限
"
" 'equalprg'         'ep'          |=|で使用する外部プログラム
"

set foldmethod=marker
set foldlevel=99
set foldtext=MyFoldText()
fun! MyFoldText()
  let l:first = substitute(getline(v:foldstart), '^\s*', '', '')
  let l:lines = v:foldend - v:foldstart + 1
  let l:info  = printf("󱞤 %4d lines ", l:lines)
  " 󰤻
  " 󱞤
  " 
  " 

  " TODO: 表示領域の幅の取得はもう少し賢くしても良いかも。
  let l:width = winwidth(0)

  let l:available = l:width - strdisplaywidth(l:info) - 5
  let l:text = strcharpart(l:first, 0, l:available)
  return l:text . repeat(' ', l:available - strdisplaywidth(l:text)) . l:info
endfun

