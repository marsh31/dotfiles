fun! s:get_main_mode_name()
  let l:m = mode()
  if l:m =~ 'i'
    return 'INS'
  elseif l:m =~ 'n'
    return 'NOR'
  elseif l:m =~ 'v'
    return 'VIS'
  elseif l:m =~ 'V'
    return 'V-LINE'
  elseif l:m =~ 'c'
    return 'COM'
  endif
