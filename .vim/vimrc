" submode-scroll {{{3

let s:scroll_latest = reltime()
let s:scroll_state = 0
fun! Do_scroll()
  let l:dftime_ms = (reltimefloat(reltime(s:scroll_latest)) * 1000)
  let s:scroll_latest = reltime()

  if (&timeout && (l:dftime_ms > &timeoutlen))
    let s:scroll_state = 0
  endif

  if     s:scroll_state == 0
    let s:scroll_state = 1
    normal! zz

  elseif s:scroll_state == 1
    let s:scroll_state = 2
    normal! zt

  elseif s:scroll_state == 2
    let s:scroll_state = 0
    normal! zb
  endif
endfun

  

